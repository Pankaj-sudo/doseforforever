rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default-deny gate
    match /{document=**} {
      allow read, write: if false;
    }

    // Global secure helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-+%]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() 
        && request.auth.token.email.lower() == 'pankaj.ydv707@gmail.com';
    }

    // User shape validator
    function isValidUser(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.name is string 
        && data.name.size() <= 120
        && data.email is string 
        && data.email.size() <= 120
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1024));
    }

    // Match rules for users collection (isolated user info)
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Normal user: strict shape validation for their own doc
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(request.resource.data)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;
        
      allow update: if isOwner(userId)
        && isValidUser(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      // Admin fallback: admin can also create/update any user doc (e.g. their own profile)
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }

    // Match rules for products collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Match rules for orders collection
    match /orders/{orderId} {
      // Admin can list all orders
      // Authed researcher can list their own orders
      allow list: if isAdmin() || (isSignedIn() && resource.data.researcherEmail == request.auth.token.email);
      
      // Public order tracking (anyone can fetch a single order by its ID)
      allow get: if true;
      
      // Anyone can submit/create an order reservation
      allow create: if request.resource.data.orderId is string 
        && request.resource.data.orderId.size() <= 128
        && request.resource.data.researcherEmail is string
        && request.resource.data.researcherEmail.size() <= 200;
        
      // Admin can update or delete orders
      allow update, delete: if isAdmin();

      // Subcollections rules
      match /order_status_history/{historyId} {
        allow read: if true;
        allow write: if isAdmin() || !exists(/databases/$(database)/documents/orders/$(orderId));
      }

      match /order_items/{itemId} {
        allow read: if true;
        allow write: if isAdmin() || !exists(/databases/$(database)/documents/orders/$(orderId));
      }
    }

    // COA shape validator
    function isValidCoa(data) {
      return data.id is string 
        && data.id.size() <= 128
        && data.peptideName is string 
        && data.peptideName.size() <= 120
        && data.batchNumber is string 
        && data.batchNumber.size() <= 120
        && data.dateTested is string 
        && data.dateTested.size() <= 64
        && data.purityPercent is number;
    }

    // Match rules for coas collection
    match /coas/{coaId} {
      allow read, get, list: if true;
      allow write: if isAdmin() && isValidCoa(request.resource.data);
    }

    // Match rules for consultations collection
    match /consultations/{consultationId} {
      // Admin can list/view all consultations
      // Authed customer can list/view their own consultations
      allow list: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);

      // Admin or the specific customer (identified securely by email) can retrieve the consultation profile
      allow get: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);

      // Anyone can submit/create a consultation request
      allow create: if request.resource.data.consultationId is string 
        && request.resource.data.consultationId.size() <= 128
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 200;

      // Admin can update or delete consultations
      allow update, delete: if isAdmin();
    }
  }
}
