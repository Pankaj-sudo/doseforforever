rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default-deny gate
    match /{document=**} {
      allow read, write: if false;
    }

    // Global secure helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-+%]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() 
        && request.auth.token.email == 'pankaj.ydv707@gmail.com' 
        && request.auth.token.email_verified == true;
    }

    // User shape validator
    function isValidUser(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.name is string 
        && data.name.size() <= 120
        && data.email is string 
        && data.email.size() <= 120
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1024));
    }

    // Match rules for users collection (isolated user info)
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(request.resource.data)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;
        
      allow update: if isOwner(userId)
        && isValidUser(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
    }

    // Match rules for products collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Match rules for orders collection
    match /orders/{orderId} {
      // Admin can list/view all orders
      allow list: if isAdmin();
      
      // Admin or the specific customer (identified securely by verified email) can get the order
      allow get: if isAdmin() || (isSignedIn() && resource.data.researcherEmail == request.auth.token.email && request.auth.token.email_verified == true);
      
      // Anyone can submit/create an order reservation
      allow create: if request.resource.data.orderId is string 
        && request.resource.data.orderId.size() <= 128
        && request.resource.data.researcherEmail is string
        && request.resource.data.researcherEmail.size() <= 200;
        
      // Admin can update or delete orders
      allow update, delete: if isAdmin();
    }

    // COA shape validator
    function isValidCoa(data) {
      return data.id is string 
        && data.id.size() <= 128
        && data.peptideName is string 
        && data.peptideName.size() <= 120
        && data.batchNumber is string 
        && data.batchNumber.size() <= 120
        && data.dateTested is string 
        && data.dateTested.size() <= 64
        && data.purityPercent is number;
    }

    // Match rules for coas collection
    match /coas/{coaId} {
      allow read, get, list: if true;
      allow write: if isAdmin() && isValidCoa(request.resource.data);
    }
  }
}
